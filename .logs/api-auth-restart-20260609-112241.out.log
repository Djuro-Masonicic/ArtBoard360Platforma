{
  id: '0f03270b-9d47-4a6a-a679-dfa2f27ab19d',
  name: 'Klara Dragović',
  slug: 'klara-dragovic',
  bio: 'Klara Dragović grafički dizajn posmatra kao interdisciplinarno polje gdje se istraživanje susreće s vizuelnom ekspresijom. Prostor u kom ideje dobijaju oblik, a informacije postaju iskustva. Kombinacijom tradicionalnih i digitalnih tehnika, razvija prilagodljive koncepte kroz analizu sadržaja i vizuelnu artikulaciju. Kompozicija, tipografija i boja služe joj kao strukturni elementi u kreiranju koherentnih sistema, bilo u primijenjenim projektima ili autonomnim istraživanjima. Teži postići ravnotežu funkcionalnosti i ekspresije, s pažnjom na proces, metodologiju i vizuelnu komunikaciju u savremenom dizajnerskom kontekstu.',
  quote: '"You are no longer the same after experiencing art." – Milton Glaser',
  email: 'klara.dragovicc@gmail.com',
  profileImageUrl: 'https://cdn.prod.website-files.com/682769f4e1ebd752d0c3e3ec/69023c30c60cecab59bc0598_compressed_Klara%20Dragovic%CC%81.webp',
