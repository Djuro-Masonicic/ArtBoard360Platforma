{
  id: 'c53ff84d-d6a8-48a9-bb3f-3054b0d5aa82',
  name: 'Mina Mijanović',
  slug: 'mina-mijanovic',
  bio: 'Mina Mijanović živi u Podgorici i završila je Fakultet za vizuelne umjetnosti, smjer grafički dizajn. Pobjednica je konkursa Tivat Photo Days 2024. godine na temu „Tranzicija“. U svom radu najviše je motivisana željom da prenese svoja iskustva i doživljaje na papir ili fotografiju. Već 14 godina bavi se plesom, s posebnim fokusom na argentinski tango, koji joj otvara vrata kreativnosti i slobode izraza. Njen pristup umjetnosti je estetski, a umjetnost doživljava kao nešto što se traži cijelog života – nezaustavljivu energiju koja živi u nama i ispoljava se u svemu što radimo.',
  quote: '"Pravi umjetnik nije onaj ko je inspirisan, nego onaj koji inspiriše druge " – Salvador Dali',
  email: 'mijanovicmina@gmail.com',
  profileImageUrl: 'https://cdn.prod.website-files.com/682769f4e1ebd752d0c3e3ec/689a1c054677cc9dafd21552_Mina%20Mijanovi%C4%87.png',
