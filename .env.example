# ---------------------------------------------------------------------------
# Shared application settings
# Copy this file to `.env` at the repository root.
# Both apps read the same file in local development to keep setup easy.
# ---------------------------------------------------------------------------

NODE_ENV=development

# ---------------------------------------------------------------------------
# API application
# Railway injects PORT automatically in deployed environments.
# API_PORT is the local fallback when PORT is not provided by the platform.
# WEB_ORIGIN accepts a comma-separated list for CORS.
# ---------------------------------------------------------------------------
PORT=4000
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
MAX_UPLOAD_FILE_SIZE_BYTES=10485760
MAX_SIGNED_UPLOAD_EXPIRY_SECONDS=900

# ---------------------------------------------------------------------------
# Database
# Development:
#   use the local Postgres container from docker-compose
# Staging / Production:
#   DATABASE_URL should be the runtime connection string
#   DIRECT_URL should be the direct connection string used by Prisma migrate
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/artboard_platforma
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/artboard_platforma

# ---------------------------------------------------------------------------
# Cloudflare R2
# R2_PUBLIC_URL should point to a public custom domain or R2 development URL.
# Example: https://media.example.com
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=artist-media
R2_PUBLIC_URL=https://media.example.com

# ---------------------------------------------------------------------------
# Email
# Resend sends the admin notification after a successful artist submission.
# Use a verified sender for RESEND_FROM_EMAIL.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# ---------------------------------------------------------------------------
# Admin authentication
# In local development these values can seed the first admin account.
# In production, always use a strong ADMIN_AUTH_SECRET and non-default credentials.
# ---------------------------------------------------------------------------
ADMIN_AUTH_SECRET=change-this-admin-auth-secret
ADMIN_AUTH_TOKEN_TTL_HOURS=12
ADMIN_SEED_EMAIL=admin@artboard.local
ADMIN_SEED_PASSWORD=change-me-admin
ADMIN_SEED_NAME=ArtBoard Admin
SITE_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Frontend
# For Vercel, set API_BASE_URL and NEXT_PUBLIC_API_BASE_URL to the public
# Railway backend URL. INTERNAL_API_BASE_URL is mainly for local Docker use.
# ---------------------------------------------------------------------------
API_BASE_URL=http://localhost:4000
INTERNAL_API_BASE_URL=http://api:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Optional CSV import paths
# These are used by the import scripts if you do not pass a file path manually.
# ---------------------------------------------------------------------------
ARTISTS_CSV_PATH=
TESTIMONIALS_CSV_PATH=
